export type Todo = {
    id: string,
    text: string,
    done: boolean,
}

export type Filter =
    | All
    | Active
    | Completed

export type Validation =
    | Valid(text: string)
    | TooShort
    | TooLong
    | Empty

export type Timestamped = {
    createdAt: number,
    updatedAt: number,
}

export type TodoWithTimestamp = {
    ...Todo,
    ...Timestamped,
}

export trait Display {
    fn display(self) -> string
}
