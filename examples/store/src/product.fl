import { Product, CartItem, SortOrder, PriceRange, Display, Discountable } from "./types"

// ── Trait implementations ──────────────────────────────

export for Product: Display fn display(self) -> string {
    `${self.title} - $${self.price}`
}

export for Product: Discountable fn effectivePrice(self) -> number {
    self.price * (1 - self.discountPercentage / 100)
}

// ── Product helpers ────────────────────────────────────

export for Product fn savings(self) -> number {
    self.price - (self |> effectivePrice)
}

export for Product fn inStock(self) -> boolean {
    self.stock > 0
}

export for Product fn stockLabel(self) -> string {
    self.stock |> match {
        0 -> "Out of stock",
        n when n < 5 -> `Only ${n} left!`,
        n when n < 20 -> "In stock",
        _ -> "Plenty in stock",
    }
}

export for Product fn ratingStars(self) -> string {
    const full = Math.floor(self.rating)

    Array.from({ length: full }, |_| "*") |> Array.join("")
}

// ── Cart operations ────────────────────────────────────

for Array<CartItem> {
    export fn addItem(self, product: Product, qty: number = 1) -> Array<CartItem> {
        const existing = self |> Array.findIndex(.product.id == product.id)

        existing |> match {
            -1 -> self |> Array.append(CartItem(product: product, quantity: qty)),
            _ -> self |> Array.map(|item|
                match item.product.id == product.id {
                    true -> CartItem(..item, quantity: item.quantity + qty),
                    false -> item,
                }
            ),
        }
    }

    export fn removeItem(self, productId: number) -> Array<CartItem> {
        self |> Array.filter(.product.id != productId)
    }

    export fn updateQuantity(self, productId: number, qty: number) -> Array<CartItem> {
        qty |> match {
            0 -> self |> removeItem(productId),
            _ -> self |> Array.map(|item|
                match item.product.id == productId {
                    true -> CartItem(..item, quantity: qty),
                    false -> item,
                }
            ),
        }
    }

    // Returns (subtotal, discount, total) as a tuple
    export fn totals(self) -> (number, number, number) {
        const subtotal = self
            |> Array.map(|item| item.product.price * item.quantity)
            |> Array.sum

        const discounted = self
            |> Array.map(|item| (item.product |> effectivePrice) * item.quantity)
            |> Array.sum

        (subtotal, subtotal - discounted, discounted)
    }

    export fn itemCount(self) -> number {
        self |> Array.map(.quantity) |> Array.sum
    }

    export fn isEmpty(self) -> boolean {
        self |> Array.isEmpty
    }
}

// ── Sorting with partial application ───────────────────

fn compareBy(order: SortOrder, a: Product, b: Product) -> number {
    order |> match {
        PriceLow -> (a |> effectivePrice) - (b |> effectivePrice),
        PriceHigh -> (b |> effectivePrice) - (a |> effectivePrice),
        Rating -> b.rating - a.rating,
        Name -> a.title |> String.localeCompare(b.title),
    }
}

export fn sortProducts(products: Array<Product>, order: SortOrder) -> Array<Product> {
    products |> Array.sort(compareBy(order, _, _))
}

// ── Price filtering with range matching ────────────────

export fn matchesPrice(product: Product, range: PriceRange) -> boolean {
    const price = product |> effectivePrice

    price |> match {
        _ when range == Any -> true,
        p when range == Under(25) -> p < 25,
        p -> match range {
            Any -> true,
            Under(max) -> p < max,
            Between(min, max) -> p >= min && p < max,
            Over(min) -> p >= min,
        },
    }
}

// ── Formatting ─────────────────────────────────────────

export fn formatPrice(amount: number) -> string {
    `$${amount |> Number.toFixed(2)}`
}

// ── Tests ──────────────────────────────────────────────

test "matchesPrice filters correctly" {
    assert true
}

test "cart totals compute discounts" {
    assert true
}
