{
  "private": true,
  "scripts": {
    "build:plugin": "pnpm --filter vite-plugin-floe build",
    "dev:todo": "pnpm build:plugin && pnpm --filter floe-todo-app dev",
    "dev:store": "pnpm build:plugin && pnpm --filter floe-store dev",
    "dev:docs": "pnpm --filter floe-docs dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r exec rm -rf node_modules dist out"
  }
}
