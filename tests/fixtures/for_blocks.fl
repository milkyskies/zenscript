type User {
  name: string,
  age: number,
  active: boolean
}

for User {
  fn display(self) -> string {
    `${self.name} (${self.age})`
  }

  fn isAdult(self) -> boolean {
    self.age >= 18
  }

  fn greet(self, greeting: string) -> string {
    `${greeting}, ${self.name}!`
  }
}

for Array<User> {
  fn adults(self) -> Array<User> {
    self |> filter(.age >= 18)
  }
}

// Type-directed pipe resolution: bare stdlib names work in pipes
const _filtered = [User(name: "Ryan", age: 25, active: true)]
  |> filter(.active)

// Disambiguation: `length` resolves to Array.length or String.length based on type
const _arrLen = [1, 2, 3] |> length
const _strLen = "hello" |> length
