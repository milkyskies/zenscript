{
  "Function Declaration": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t$0",
      "}"
    ],
    "description": "Function declaration"
  },
  "Export Function": {
    "prefix": "efn",
    "body": [
      "export fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t$0",
      "}"
    ],
    "description": "Exported function declaration"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:pattern} -> ${3:body},",
      "\t_ -> ${0:default},",
      "}"
    ],
    "description": "Match expression"
  },
  "Match with Guard": {
    "prefix": "matchw",
    "body": [
      "match ${1:expr} {",
      "\t${2:pattern} when ${3:condition} -> ${4:body},",
      "\t_ -> ${0:default},",
      "}"
    ],
    "description": "Match expression with guard"
  },
  "Match Result": {
    "prefix": "matchr",
    "body": [
      "match ${1:result} {",
      "\tOk(${2:value}) -> ${3:body},",
      "\tErr(${4:error}) -> ${0:errorBody},",
      "}"
    ],
    "description": "Match on Result"
  },
  "Match Option": {
    "prefix": "matcho",
    "body": [
      "match ${1:option} {",
      "\tSome(${2:value}) -> ${3:body},",
      "\tNone -> ${0:default},",
      "}"
    ],
    "description": "Match on Option"
  },
  "Type Record": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = {",
      "\t${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Record type declaration"
  },
  "Type Union": {
    "prefix": "union",
    "body": [
      "type ${1:Name} =",
      "\t| ${2:Variant1}",
      "\t| ${3:Variant2}"
    ],
    "description": "Union type declaration"
  },
  "React Component": {
    "prefix": "comp",
    "body": [
      "export fn ${1:Component}() -> JSX.Element {",
      "\treturn <div>",
      "\t\t$0",
      "\t</div>",
      "}"
    ],
    "description": "React component"
  },
  "Import": {
    "prefix": "imp",
    "body": [
      "import { ${2:name} } from \"${1:module}\""
    ],
    "description": "Import statement"
  },
  "Pipe": {
    "prefix": "pipe",
    "body": [
      "${1:value} |> ${0:transform}"
    ],
    "description": "Pipe expression"
  },
  "Const": {
    "prefix": "co",
    "body": [
      "const ${1:name} = ${0:value}"
    ],
    "description": "Const declaration"
  },
  "Branded Type": {
    "prefix": "brand",
    "body": [
      "type ${1:Name} = Brand<${2:string}, \"${1:Name}\">"
    ],
    "description": "Branded type"
  },
  "Opaque Type": {
    "prefix": "opaque",
    "body": [
      "opaque type ${1:Name} = ${2:BaseType}"
    ],
    "description": "Opaque type"
  },
  "For Block": {
    "prefix": "for",
    "body": [
      "for ${1:Type} {",
      "\texport fn ${2:name}(self) -> ${3:ReturnType} {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "For block - group functions under a type"
  },
  "Inline For Declaration": {
    "prefix": "efor",
    "body": [
      "export for ${1:Type} fn ${2:name}(self) -> ${3:ReturnType} {",
      "\t$0",
      "}"
    ],
    "description": "Inline for-declaration (single function)"
  },
  "Import For Type": {
    "prefix": "impfor",
    "body": [
      "import { for ${2:Type} } from \"${1:module}\""
    ],
    "description": "Import for-block functions by type"
  },
  "Trait Declaration": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "\tfn ${2:method}(self) -> ${3:ReturnType}",
      "}"
    ],
    "description": "Trait declaration"
  },
  "Trait Implementation": {
    "prefix": "impl",
    "body": [
      "for ${1:Type}: ${2:Trait} {",
      "\tfn ${3:method}(self) -> ${4:ReturnType} {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Trait implementation"
  },
  "Tap Debug": {
    "prefix": "tap",
    "body": [
      "tap(${1:Console.log})"
    ],
    "description": "Tap for pipeline debugging"
  },
  "Test Block": {
    "prefix": "test",
    "body": [
      "test \"${1:name}\" {",
      "\tassert ${0:expression}",
      "}"
    ],
    "description": "Inline test block"
  },
  "Todo Placeholder": {
    "prefix": "todo",
    "body": [
      "todo"
    ],
    "description": "Placeholder that panics at runtime (type never)"
  },
  "Unreachable": {
    "prefix": "unreachable",
    "body": [
      "unreachable"
    ],
    "description": "Assert unreachable code path (type never)"
  }
}
