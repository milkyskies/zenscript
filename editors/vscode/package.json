{
  "name": "floe",
  "displayName": "Floe",
  "description": "Language support for Floe (.fl) - syntax highlighting, diagnostics, and LSP integration",
  "version": "0.1.9",
  "license": "MIT",
  "publisher": "floeorg",
  "icon": "icons/floe-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/milkyskies/floe"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:floe"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "floe",
        "aliases": [
          "Floe",
          "floe"
        ],
        "extensions": [
          ".fl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "../../assets/logo.svg",
          "dark": "../../assets/logo.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "floe",
        "scopeName": "source.floe",
        "path": "./syntaxes/floe.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "floe",
        "path": "./snippets/floe.json"
      }
    ],
    "configuration": {
      "title": "Floe",
      "properties": {
        "floe.serverPath": {
          "type": "string",
          "default": "floe",
          "description": "Path to the floe binary"
        },
        "floe.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Floe language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
