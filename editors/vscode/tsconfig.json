{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "out"]
}
