{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Floe",
  "scopeName": "source.floe",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-literals" },
    { "include": "#jsx" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#lambda" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.floe",
          "match": "//.*$"
        },
        {
          "name": "comment.block.floe",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.floe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.floe",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-literals": {
      "patterns": [
        {
          "name": "string.template.floe",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.floe",
              "match": "\\\\."
            },
            {
              "name": "meta.template.expression.floe",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.floe" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.floe" }
              },
              "patterns": [
                { "include": "source.floe" }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.floe",
          "match": "\\b(match|return|await|async|try|for|when)\\b"
        },
        {
          "name": "keyword.control.import.floe",
          "match": "\\b(import|from|export|trusted)\\b"
        },
        {
          "name": "keyword.other.floe",
          "match": "\\b(opaque)\\b"
        },
        {
          "name": "variable.language.floe",
          "match": "\\b(Ok|Err|Some|None|self)\\b"
        },
        {
          "name": "constant.language.boolean.floe",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "invalid.illegal.keyword.floe",
          "match": "\\b(let|var|class|enum|throw|null|undefined|any|as|function)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.floe",
          "match": "\\b(const|fn|type)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.underscore.floe",
          "match": "\\b_\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.floe",
          "match": "\\b(number|string|boolean|void|unknown)\\b"
        },
        {
          "name": "support.type.builtin.floe",
          "match": "\\b(Result|Option|Brand|Array|Promise|JSX)\\b"
        },
        {
          "comment": "Generic type parameters: <Type>",
          "begin": "<",
          "end": ">",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.begin.floe" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.floe" }
          },
          "patterns": [
            { "include": "#types" },
            {
              "name": "punctuation.separator.comma.floe",
              "match": ","
            }
          ]
        },
        {
          "comment": "User-defined types (PascalCase identifiers)",
          "name": "entity.name.type.floe",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.floe",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.floe",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.floe",
          "match": "=>"
        },
        {
          "name": "keyword.operator.unwrap.floe",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.spread.floe",
          "match": "\\.\\.(?!\\.)"
        },
        {
          "name": "keyword.operator.comparison.floe",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.logical.floe",
          "match": "&&|!"
        },
        {
          "name": "keyword.operator.arithmetic.floe",
          "match": "[+*/%]"
        },
        {
          "comment": "Minus sign — but not when part of ->",
          "name": "keyword.operator.arithmetic.floe",
          "match": "-(?!>)"
        },
        {
          "name": "keyword.operator.assignment.floe",
          "match": "(?<!=|!)="
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "fn declarations",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.floe" },
            "2": { "name": "entity.name.function.floe" }
          }
        },
        {
          "comment": "Function calls",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.floe" }
          }
        }
      ]
    },
    "lambda": {
      "patterns": [
        {
          "comment": "Zero-arg lambda: ||",
          "match": "(\\|)(\\|)(?!>|\\|)",
          "captures": {
            "1": { "name": "punctuation.definition.parameters.begin.floe" },
            "2": { "name": "punctuation.definition.parameters.end.floe" }
          }
        },
        {
          "comment": "Pipe lambda parameters: |x| or |a, b|",
          "match": "(\\|)([^|>][^|]*?)(\\|)(?!>)",
          "captures": {
            "1": { "name": "punctuation.definition.parameters.begin.floe" },
            "2": { "name": "variable.parameter.floe" },
            "3": { "name": "punctuation.definition.parameters.end.floe" }
          }
        },
        {
          "comment": "Union type bar",
          "name": "keyword.operator.union.floe",
          "match": "\\|(?!>|\\|)"
        }
      ]
    },
    "jsx": {
      "patterns": [
        {
          "comment": "JSX closing tag",
          "match": "(</)([A-Z][a-zA-Z0-9]*|[a-z][a-zA-Z0-9-]*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.floe" },
            "2": { "name": "entity.name.tag.floe" },
            "3": { "name": "punctuation.definition.tag.end.floe" }
          }
        },
        {
          "comment": "JSX opening/self-closing tag",
          "begin": "(<)([A-Z][a-zA-Z0-9]*|[a-z][a-zA-Z0-9-]*)(?=[\\s/>])",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.floe" },
            "2": { "name": "entity.name.tag.floe" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.floe" }
          },
          "patterns": [
            { "include": "#jsx-attributes" }
          ]
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "comment": "JSX expression attribute: prop={expr}",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.floe" },
            "2": { "name": "keyword.operator.assignment.floe" },
            "3": { "name": "punctuation.section.embedded.begin.floe" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.section.embedded.end.floe" }
          },
          "patterns": [
            { "include": "source.floe" }
          ]
        },
        {
          "comment": "JSX string attribute: prop=\"value\"",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.floe" },
            "2": { "name": "keyword.operator.assignment.floe" },
            "3": { "name": "string.quoted.double.floe" }
          }
        },
        {
          "comment": "JSX bare attribute name",
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.floe" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.floe",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.floe",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
